{
  "env": {
    "browser": true,
    "es6": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/eslint-recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:import/recommended",
    "plugin:import/electron",
    "plugin:import/typescript"
  ],
  "settings": {
    "import/ignore": [
      "^@tailwindcss/vite$",
      "^@vitejs/plugin-react$",
      "^vite$",
      "^vitest/config$"
    ]
  },
  "rules": {
    "import/no-unresolved": [
      "error",
      {
        "ignore": [
          "^@tailwindcss/vite$",
          "^@vitejs/plugin-react$",
          "^vite$",
          "^vitest/config$",
          "^@/",
          "^virtual:darkreader-script$"
        ]
      }
    ]
  },
  "parser": "@typescript-eslint/parser"
}
